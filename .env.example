# AI provider — at least one of ANTHROPIC_API_KEY or OPENAI_API_KEY is required
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default model (provider/model format). Defaults to anthropic/claude-sonnet-4-20250514.
# Examples:
#   anthropic/claude-sonnet-4-20250514   (default, best tool-calling)
#   anthropic/claude-haiku-4-5-20251001  (faster, cheaper, still good)
#   openai/gpt-4o                        (requires OPENAI_API_KEY)
#   openai/o3-mini                       (requires OPENAI_API_KEY)
OPENCLAW_MODEL=

# Optional — Telegram bot interface
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# Optional — GitHub CLI (github.com/settings/tokens)
GITHUB_TOKEN=

# Optional — SMS notifications via Surge
SURGE_SMS_API_KEY=

# Optional — Google Workspace (also place client_secret.json next to setup.sh)
# Download from GCP Console → APIs & Services → Credentials → your OAuth client → Download JSON
