# OpenClaw Bot Configuration Template
#
# Copy this file to configs/<name>.env and fill in the values.
# Or use: ./manage.sh scaffold <name>
#
# Variables referencing ${...} are inherited from .env.local (shared keys).
# Replace with a literal value to override per bot.

# === Basic VM Settings ===
VM_NAME=mybot
OPENCLAW_PORT=18793
WORKSPACE_DIR=./workspace-mybot

# === Bot Identity ===
BOT_NAME="My Bot"
BOT_DESCRIPTION="My Bot - AI assistant for various tasks"

# === API Keys ===
# Inherited from .env.local by default. Override here if this bot needs its own keys.
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
OPENAI_API_KEY=${OPENAI_API_KEY}

# === Telegram ===
# Each bot needs its own token from @BotFather (https://t.me/BotFather).
# This is the one value you MUST set per bot.
TELEGRAM_BOT_TOKEN=

# === GitHub ===
GITHUB_TOKEN=${GITHUB_TOKEN}

# === Google Workspace ===
GOOGLE_WORKSPACE_CREDENTIALS_FILE=${GOOGLE_WORKSPACE_CREDENTIALS_FILE}

# === Feature Flags ===
ENABLE_EMAIL_SENDING=true
ENABLE_CODE_EXECUTION=true
ENABLE_WEB_BROWSING=true
ENABLE_CRON_JOBS=true

# === Security & Approval Settings ===
# Set to true to skip approval prompts (less secure)
AUTO_APPROVE_EMAIL=false
AUTO_APPROVE_FILE_OPERATIONS=false
AUTO_APPROVE_WEB_REQUESTS=false

# Skip all approvals (development only -- not recommended for production)
OPENCLAW_SKIP_APPROVALS=false

# === Advanced Settings ===
NODE_OPTIONS="--max-old-space-size=2048"
LOG_LEVEL=info

# Override the default Anthropic model (uncomment to change)
# ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# === Skills Configuration ===
ENABLE_BROWSER_SKILLS=true
ENABLE_CLAWDBOT_SKILLS=true
ENABLE_WORKSPACE_SKILLS=true
OPENCLAW_SKILLS="openclaw-agent-browser-clawdbot,gws-workspace,github"
